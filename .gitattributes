# ==============================================================================
# Git Attributes - Line Endings & Binary Files
# ==============================================================================

# Auto detect text files and normalize line endings to LF
* text=auto

# ==============================================================================
# Source Code
# ==============================================================================
*.py text eol=lf diff=python
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# ==============================================================================
# Documentation
# ==============================================================================
*.md text eol=lf diff=markdown
*.txt text eol=lf
LICENSE text eol=lf
README text eol=lf

# ==============================================================================
# Configuration
# ==============================================================================
*.ini text eol=lf
*.cfg text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# ==============================================================================
# Shell Scripts
# ==============================================================================
*.sh text eol=lf
*.ps1 text eol=crlf

# ==============================================================================
# Git LFS - Large Binary Files
# ==============================================================================
# NOTE: These files are tracked by .gitignore and excluded from repo
# Uncomment if you decide to use Git LFS instead:

# Models & Weights (Large files)
# *.onnx filter=lfs diff=lfs merge=lfs -text
# *.pt filter=lfs diff=lfs merge=lfs -text
# *.pth filter=lfs diff=lfs merge=lfs -text

# Data files
# *.npy filter=lfs diff=lfs merge=lfs -text
# *.npz filter=lfs diff=lfs merge=lfs -text

# Images
# *.jpg filter=lfs diff=lfs merge=lfs -text
# *.png filter=lfs diff=lfs merge=lfs -text

# ==============================================================================
# Binary Files (not tracked by Git LFS, excluded by .gitignore)
# ==============================================================================
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.pt binary
*.pth binary
*.onnx binary
*.npy binary
*.npz binary
*.pkl binary
*.zip binary
*.tar binary
*.gz binary

# ==============================================================================
# Models & Weights (Large Binary Files)
# ==============================================================================
# YOLOE model (70MB) - download separately
models/yoloe-11l-seg-pf.pt

# MobileCLIP model directory (380MB total) - download from Hugging Face
models/mobileclip_s2/

# YOLO11 trained models
models/*.onnx
models/*.pt

# Keep model documentation
!models/DOWNLOAD_MODELS.md
!models/.gitkeep

# Pretrained weights directory
weights/
!weights/.gitkeep

# ==============================================================================
# Dataset & Reference Images
# ==============================================================================
# Training images (25 images, ~30MB total)
data/images/*.jpg
data/images/*.png
data/images/*.jpeg

# YOLO labels
data/labels/*.txt

# Reference images (30 images across 5 classes)
data/ref_images/**/*.jpg
data/ref_images/**/*.png
data/ref_images/**/*.jpeg

# YOLO dataset splits
data/yolov11_dataset/

# Keep directory structure and documentation
!data/images/.gitkeep
!data/labels/.gitkeep
!data/ref_images/.gitkeep
!data/DATA_STRUCTURE.md

# ==============================================================================
# SQLite Database
# ==============================================================================
# Exclude SQLite database file (contains cached embeddings and detection history)
*.db
*.db-journal
*.db-shm
*.db-wal

# Legacy embedding database (no longer used)
db/vectors.npy
db/labels.txt
!db/.gitkeep

# ==============================================================================
# Outputs & Results
# ==============================================================================
outputs/**/*.jpg
outputs/**/*.png
!outputs/.gitkeep
!outputs/pipeline/.gitkeep

# ==============================================================================
# Training & Logs
# ==============================================================================
runs/
logs/
*.log
wandb/
checkpoints/

# ==============================================================================
